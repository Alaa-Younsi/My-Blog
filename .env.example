# Dead Side — Environment Variables Template
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and will NEVER be committed.
#
# All client-side variables MUST be prefixed with VITE_
# (Vite strips any variable without this prefix from the bundle)

# ─── Analytics ───────────────────────────────────────────────
# VITE_ANALYTICS_ID=

# ─── API (if you add a backend / CMS) ────────────────────────
# VITE_API_URL=

# ─── Site URL (used for canonical / OG URLs) ─────────────────
# VITE_SITE_URL=https://deadside.vercel.app
